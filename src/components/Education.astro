---
import { siteConfig } from "../config";
const config = Astro.props.config ?? siteConfig;
const sectionLabels = Astro.props.sectionLabels ?? {};
const hasEducation = config.education && config.education.length > 0;

const icons = {
  briefcase:
    "M10 6h4a2 2 0 0 1 2 2v1h3a2 2 0 0 1 2 2v7a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-7a2 2 0 0 1 2 -2h3v-1a2 2 0 0 1 2 -2z M8 9h8 M3 13h18 M9 13v2h6v-2",
  university:
    "M4 10l8 -5l8 5 M6 10v8 M10 10v8 M14 10v8 M18 10v8 M4 18h16 M3 21h18",
  analytics:
    "M4 19v-7 M9 19v-11 M14 19v-5 M19 19v-14 M3 19h18 M5 8l4 -3l5 4l5 -6",
  certificate:
    "M12 15a5 5 0 1 0 0 -10a5 5 0 0 0 0 10z M8.5 14l-1.5 7l5 -3l5 3l-1.5 -7 M10 10l1.5 1.5l3 -3",
};
---

{
  hasEducation && (
    <section id="education" class="bg-slate-50 p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              {sectionLabels.education ?? "Education & Continuous Learning"}
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${config.accentColor}`}
            />
            <p class="mt-6 max-w-sm text-base leading-7 text-gray-600">
              {sectionLabels.educationIntro ??
                "Formal education and recent learning that support my transition from client-facing CMMS work into stronger R&D, analytics, management, and product strategy contributions."}
            </p>
          </div>

          <div class="lg:col-span-8">
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
              {config.education.map((edu) => (
                <article class="group rounded-lg border border-slate-200 bg-white p-4 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-200 hover:shadow-md sm:p-5">
                  <div class="mb-5 flex items-start gap-4">
                    <div
                      class="grid h-12 w-12 shrink-0 place-items-center rounded-lg bg-gray-950 text-white transition-transform duration-300 group-hover:scale-105"
                      style={`box-shadow: 0 0 0 1px ${config.accentColor}22`}
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="h-5 w-5"
                        aria-hidden="true"
                      >
                        <path d={icons[edu.icon] ?? icons.certificate} />
                      </svg>
                    </div>
                    <div class="min-w-0">
                      <h3 class="text-lg font-bold leading-snug text-gray-950 sm:text-xl">
                        {edu.degree}
                      </h3>
                      <p
                        class="mt-1 text-base font-semibold"
                        style={`color: ${config.accentColor}`}
                      >
                        {edu.school}
                      </p>
                      <span class="mt-2 inline-block rounded-md bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600">
                        {edu.dateRange}
                      </span>
                    </div>
                  </div>

                  <ul class="space-y-3">
                    {edu.achievements.map((achievement) => (
                      <li class="flex items-start gap-3">
                        <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gray-950" />
                        <span class="text-sm leading-6 text-gray-600 sm:text-base">
                          {achievement}
                        </span>
                      </li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
