---
import { siteConfig } from "../config";

const config = Astro.props.config ?? siteConfig;
const navLabels = Astro.props.navLabels ?? {};

const hasProjects = config.projects && config.projects.length > 0;
const hasWorkingStyle =
  config.workingStyle && config.workingStyle.qualities.length > 0;
const hasExperience = config.experience && config.experience.length > 0;
const hasEducation = config.education && config.education.length > 0;
const hasWhyRnd = !!config.whyRnd;
---

<footer class="relative bg-gray-50 border-t border-gray-200">
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-8">
    <div
      class="flex flex-col md:flex-row md:items-center md:justify-between gap-8"
    >
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
          {config.avatarImage && (
            <img
              src={config.avatarImage}
              alt=""
              class="h-10 w-10 rounded-full object-cover ring-1 ring-blue-200"
              loading="lazy"
            />
          )}
          <h3 class="text-2xl font-bold text-gray-800">
            {config.name}
          </h3>
        </div>
        <p class="text-base text-gray-600">
          {config.title}
        </p>
        <div class="flex gap-x-6">
          <a
            href={`mailto:${config.social.email}`}
            aria-label="Email"
            class="text-gray-600 transition-colors duration-300 hover:text-[var(--accent-color)]"
            style={`--accent-color: ${config.accentColor}`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-6 w-6"
            >
              <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
              <path
                d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"
              ></path>
              <path d="M3 7l9 6l9 -6"></path>
            </svg>
          </a>
          {
            config.social.linkedin && (
              <a
                href={config.social.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"
                class="text-gray-600 transition-colors duration-300 hover:text-[var(--accent-color)]"
                style={`--accent-color: ${config.accentColor}`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-6 w-6"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M8 11v5" />
                  <path d="M8 8v.01" />
                  <path d="M12 16v-5" />
                  <path d="M16 16v-3a2 2 0 1 0 -4 0" />
                  <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
                </svg>
              </a>
            )
          }
          {
            config.social.twitter && (
              <a
                href={config.social.twitter}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Twitter"
                class="text-gray-600 transition-colors duration-300 hover:text-[var(--accent-color)]"
                style={`--accent-color: ${config.accentColor}`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-6 w-6"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M4 4l11.733 16h4.267l-11.733 -16z" />
                  <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772" />
                </svg>
              </a>
            )
          }
          {
            config.social.github && (
              <a
                href={config.social.github}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
                class="text-gray-600 transition-colors duration-300 hover:text-[var(--accent-color)]"
                style={`--accent-color: ${config.accentColor}`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-6 w-6"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
                </svg>
              </a>
            )
          }
        </div>
      </div>

      <div class="hidden md:block flex flex-col md:items-end gap-4">
        <nav class="flex gap-x-8">
          {
            hasWhyRnd && (
              <a
                href="#why-rnd"
                class="text-sm text-gray-600 hover:text-gray-800 transition-colors"
              >
                {navLabels.why ?? "Why R&D"}
              </a>
            )
          }
          <a
            href="#about"
            class="text-sm text-gray-600 hover:text-gray-800 transition-colors"
            >{navLabels.about ?? "About"}</a
          >
          {
            hasWorkingStyle && (
              <a
                href="#working-style"
                class="text-sm text-gray-600 hover:text-gray-800 transition-colors"
              >
                {navLabels.style ?? "Style"}
              </a>
            )
          }
          {
            hasProjects && (
              <a
                href="#showcases"
                class="text-sm text-gray-600 hover:text-gray-800 transition-colors"
              >
                {navLabels.showcases ?? "Showcases"}
              </a>
            )
          }
          {
            hasExperience && (
              <a
                href="#experience"
                class="text-sm text-gray-600 hover:text-gray-800 transition-colors"
              >
                {navLabels.experience ?? "Experience"}
              </a>
            )
          }
          {
            hasEducation && (
              <a
                href="#education"
                class="text-sm text-gray-600 hover:text-gray-800 transition-colors"
              >
                {navLabels.education ?? "Education"}
              </a>
            )
          }
        </nav>
        <p class="text-sm text-gray-500">
          © {new Date().getFullYear()}
          {config.name}. All rights reserved.
        </p>
      </div>
    </div>
  </div>

  <!-- Decorative pattern -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <svg
      aria-hidden="true"
      class="absolute bottom-0 left-0 w-full h-24 text-gray-100"
    >
      <pattern
        id="footer-pattern"
        x="0"
        y="0"
        width="100"
        height="100"
        patternUnits="userSpaceOnUse"
      >
        <path
          d="M0 50 Q 25 40, 50 50 T 100 50"
          stroke="currentColor"
          stroke-width="0.5"
          fill="none"
          opacity="0.4"></path>
      </pattern>
      <rect width="100%" height="100%" fill="url(#footer-pattern)"></rect>
    </svg>
  </div>
</footer>
