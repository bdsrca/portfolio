const showcaseIntro = propsShowcaseIntro ?? defaultShowcaseIntro;
const showcaseTiers = propsShowcaseTiers ?? defaultShowcaseTiers;
---

<section
  id="showcases"
  class="relative isolate overflow-hidden bg-gray-950 px-6 py-12 sm:p-12 md:p-16 lg:p-24"
>
  <img
    src="/showcases/generated/portfolio-dark-background.png"
    alt=""
    class="absolute inset-0 -z-10 h-full w-full object-cover opacity-30"
    loading="lazy"
  />
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-b from-gray-950/88 via-gray-950/94 to-gray-950"
  />

  <div class="mx-auto max-w-7xl">
    <div class="max-w-3xl">
      <h2 class="text-3xl font-bold text-white sm:text-4xl md:text-5xl">
        Showcases
      </h2>
      <div
        class="mt-3 h-[5px] w-[75px] rounded-full"
        style={`background-color: ${config.accentColor}`}
      />
      <p class="mt-6 text-sm leading-7 text-gray-300 sm:text-base">
        {showcaseIntro}
      </p>
    </div>

    <div class="mt-12 space-y-14">
      {
        showcaseTiers.map((tier, tierIndex) => (
          <section
            class:list={[
              "showcase-tier rounded-lg border p-4 sm:p-5",
              tier.accent === "blue" &&
                "border-blue-300/15 bg-blue-500/[0.045]",
              tier.accent === "emerald" &&
                "border-emerald-300/15 bg-emerald-500/[0.045]",
              tier.accent === "violet" &&
                "border-violet-300/15 bg-violet-500/[0.045]",
            ]}
            aria-labelledby={`showcase-tier-${tierIndex}`}
            data-showcase-tier
          >
            <div class="mb-6 max-w-4xl">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-200/80">
                Tier {tierIndex + 1}
              </p>
              <h3
                id={`showcase-tier-${tierIndex}`}
                class="mt-2 text-2xl font-bold text-white sm:text-3xl"
              >
                {tier.title}
              </h3>
              <p class="mt-3 text-sm leading-7 text-gray-300">{tier.description}</p>
            </div>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
              {tier.projects.map((project) => (
                <article class="flex h-full">
                  <div
                    class="showcase-card group h-full w-full overflow-hidden rounded-lg border border-white/12 bg-white text-gray-950 shadow-2xl shadow-blue-950/20 transition duration-300 hover:-translate-y-1 hover:border-blue-200 focus-within:border-blue-200"
                    data-showcase-card
                  >
                    <button
                      type="button"
                      class="showcase-visual relative block h-[18rem] w-full cursor-pointer list-none overflow-hidden bg-slate-100 text-left focus:outline-none focus-visible:ring-4 focus-visible:ring-blue-300 sm:h-[20rem] xl:h-[22rem]"
                      aria-label={`Show technical flow for ${project.title}`}
                      aria-pressed="false"
                      aria-expanded="false"
                      data-showcase-toggle
                    >
                      <img
                        src={project.cover}
                        alt={`${project.title} cartoon project illustration`}
                        class="showcase-cover absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                        loading="lazy"
                      />

                      <div class="showcase-visual-caption absolute inset-x-0 bottom-0 z-10 bg-gradient-to-t from-slate-950/90 via-slate-950/68 to-transparent p-5 pt-14 transition duration-300 group-hover:opacity-0">
                        <p class="text-[0.72rem] font-bold uppercase tracking-[0.18em] text-blue-100">
                          {project.category}
                        </p>
                        <h4 class="mt-1.5 text-lg font-bold leading-tight text-white">
                          {project.title}
                        </h4>
                        <p class="mt-1.5 line-clamp-2 text-sm leading-5 text-slate-100">
                          {project.description}
                        </p>
                      </div>

                      <div
                        class="showcase-diagram absolute inset-0 flex flex-col justify-center gap-2.5 bg-slate-950/95 p-5 opacity-0 transition duration-300 group-hover:translate-y-0 group-hover:opacity-100"
                        aria-label={`${project.title} technical diagram`}
                      >
                        <div class="mb-1.5">
                          <p class="text-[0.7rem] font-bold uppercase tracking-[0.16em] text-blue-200">
                            Technical Flow
                          </p>
                          <h4 class="mt-1 line-clamp-1 text-base font-bold leading-tight text-white">
                            {project.title}
                          </h4>
                        </div>
                        {project.diagram.map((node, nodeIndex) => (
                          <div class="flex items-center gap-2.5">
                            <div class="min-w-0 flex-1 rounded-md border border-blue-200/25 bg-white/9 px-3.5 py-2.5 text-[0.82rem] font-semibold leading-snug text-white shadow-sm">
                              {node}
                            </div>
                            {nodeIndex < project.diagram.length - 1 && (
                              <span class="shrink-0 text-base font-bold text-blue-200" aria-hidden="true">
                                →
                              </span>
                            )}
                          </div>
                        ))}
                      </div>
                    </button>

                    <div class="showcase-details flex flex-col overflow-hidden px-6">
                      <div class="py-6">
                      <p class="text-xs font-bold uppercase tracking-[0.18em] text-blue-700">
                        {project.category}
                      </p>
                      <h4 class="mt-3 text-xl font-bold leading-tight text-gray-950">
                        {project.title}
                      </h4>
                      <p class="mt-3 text-sm leading-6 text-gray-700">
                        {project.description}
                      </p>

                      <div class="mt-5 space-y-3 text-sm leading-6 text-gray-700">
                        {project.fields.map((field) => (
                          <div class="rounded-md bg-slate-50 p-3 ring-1 ring-slate-200">
                            <p class="text-[0.7rem] font-bold uppercase tracking-[0.14em] text-blue-700">
                              {field.label}
                            </p>
                            <p class="mt-1 text-sm leading-6 text-gray-700">
                              {field.text}
                            </p>
                          </div>
                        ))}
                      </div>

                      <div class="mt-5 flex flex-wrap gap-2">
                        {project.tags.slice(0, 5).map((tag) => (
                          <span class="rounded-full border border-gray-200 bg-gray-50 px-3 py-1 text-xs font-semibold text-gray-700">
                            {tag}
                          </span>
                        ))}
                      </div>

                      <div class="mt-auto pt-6">
                        {project.link ? (
                          <a
                            href={project.link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center justify-center gap-2 rounded-md bg-gray-950 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-blue-700 focus:outline-none focus-visible:ring-4 focus-visible:ring-blue-300"
                          >
                            {project.linkLabel ?? "View Case Study"}
                            <svg
                              class="h-4 w-4"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <path d="M7 17 17 7" />
                              <path d="M7 7h10v10" />
                            </svg>
                          </a>
                        ) : (
                          <span class="inline-flex items-center justify-center rounded-md border border-gray-200 px-4 py-2.5 text-sm font-bold text-gray-500">
                            Case Study Coming Soon
                          </span>
                        )}
                      </div>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[data-showcase-toggle]").forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const card = toggle.closest("[data-showcase-card]");
      const tier = toggle.closest("[data-showcase-tier]");
      if (!card || !tier) return;

      const willActivate = card.getAttribute("data-active") !== "true";
      tier.querySelectorAll("[data-showcase-card]").forEach((tierCard) => {
        tierCard.removeAttribute("data-active");
        tierCard
          .querySelector("[data-showcase-toggle]")
          ?.setAttribute("aria-pressed", "false");
        tierCard
          .querySelector("[data-showcase-toggle]")
          ?.setAttribute("aria-expanded", "false");
      });

      if (willActivate) {
        tier.setAttribute("data-expanded", "true");
        card.setAttribute("data-active", "true");
        toggle.setAttribute("aria-pressed", "true");
        toggle.setAttribute("aria-expanded", "true");
      } else {
        tier.removeAttribute("data-expanded");
      }
    });
  });
</script>

<style>
  .showcase-diagram {
    transform: translateY(0.5rem);
  }

  .showcase-card[data-active="true"] {
    border-color: rgb(191 219 254);
    box-shadow:
      0 0 0 2px rgb(147 197 253 / 0.35),
      0 25px 50px -12px rgb(30 64 175 / 0.32);
  }

  .showcase-card[data-active="true"] .showcase-visual-caption {
    opacity: 0;
  }

  .showcase-card[data-active="true"] .showcase-diagram {
    opacity: 1;
    transform: translateY(0);
