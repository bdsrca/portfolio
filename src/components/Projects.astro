---
import { siteConfig } from "../config";

const config = Astro.props.config ?? siteConfig;
const propsShowcaseIntro = Astro.props.showcaseIntro;
const propsShowcaseTiers = Astro.props.showcaseTiers;

const defaultShowcaseIntro =
  "Selected R&D systems, engineering case studies, and full-stack experiments that turn repeated workflow friction into safer automation, AI-assisted operations, legacy modernization, and product-ready control patterns.";

const showcaseImageMap = {
  localAiApi: "/showcases/generated/cmms-local-ai-api-console-cover.png",
  automationRules: "/showcases/generated/cmms-automation-rules-cover.png",
  megamationUpgrade:
    "/showcases/generated/megamation-basic-upgrade-workstation-cover.png",
  knowledgeBase: "/showcases/generated/cmms-knowledge-base-cover-new.png",
  analyticsExport: "/showcases/generated/cmms-analytics-export-api-cover.png",
  mobilePwa: "/showcases/generated/cmms-mobile-pwa-architecture-cover.png",
  agenticEam: "/showcases/generated/cmms-agentic-eam-cover.png",
  aiOperations:
    "/showcases/generated/cmms-ai-operations-console-roadmap-cover.png",
  studentMarketplace:
    "/showcases/generated/student-help-student-marketplace-cover.png",
};

const defaultShowcaseTiers = [
  {
    title: "Featured R&D Systems",
    accent: "blue",
    description:
      "Core projects that best represent my R&D direction: CMMS modernization, safe AI-assisted workflows, automation governance, and legacy system upgrade tooling.",
    projects: [
      {
        category: "Featured R&D System",
        title: "CMMS Local AI API Management Console",
        description:
          "A private local CMMS AI API console that keeps prompts, test data, and token use under my own control.",
        buildLabel: "Built a private control plane",
        built:
          "Runs text and voice intake through local Ollama models, then checks the result against environment code lists, output contracts, saved tests, logs, and promotion gates.",
        valueLabel: "Keeps AI testing private and flexible",
        rdValue:
          "Teams can experiment without sending CMMS data away, worrying about token limits, or trusting raw model output as final.",
        fields: [
          {
            label: "Problem",
            text: "AI workflow experiments need realistic CMMS constraints, but production data, token cost, and raw model output are risky places to start.",
          },
          {
            label: "Technical Approach",
            text: "A local control plane runs intake through Ollama, validates outputs against code lists and contracts, saves tests and logs, and promotes only reviewed patterns.",
          },
          {
            label: "Why It Matters",
            text: "R&D can test AI-assisted workflow ideas privately while support and implementation teams keep clear evidence of what was tested.",
          },
          {
            label: "Legacy System Meaning",
            text: "It lets DirectLine-adjacent ideas be explored beside the core system, using legacy rules as guardrails instead of replacing the system.",
          },
        ],
        tags: [
          "Private AI",
          "Local LLM",
          "CMMS API",
          "Validation Rules",
          "Unlimited Tokens",
        ],
        cover: showcaseImageMap.localAiApi,
        link: "https://github.com/bdsrca/cmms-api",
        diagram: [
          "Natural Language Request",
          "LLM Extraction",
          "Output Contract",
          "Environment Validation",
          "Promotion/Test Gate",
          "Structured API Response",
        ],
      },
      {
        category: "Featured R&D System",
        title: "CMMS Automation Rules",
        description:
          "A CMMS rule engine that previews alerts, reports, notifications, and work-order actions before anything runs live.",
        buildLabel: "Previewed automation before rollout",
        built:
          "Starts rules disabled, shows dry-run results, controls notifications, and records every decision in an audit trail.",
        valueLabel: "Turns automation into a safe workflow",
        rdValue:
          "Users can see what a rule would do before it touches live alerts, reports, or work orders.",
        fields: [
          {
            label: "Problem",
            text: "Operational automation can become noisy or dangerous when rules move directly from idea to live alerts, reports, or work-order actions.",
          },
          {
            label: "Technical Approach",
            text: "Rules start disabled, run in dry-run mode, preview notifications and actions, and record decisions in an audit trail before rollout.",
          },
          {
            label: "Why It Matters",
            text: "Users, support, and implementation teams can understand automation behavior before trusting it in daily maintenance work.",
          },
          {
            label: "Legacy System Meaning",
            text: "It adds controlled automation patterns around established CMMS workflows without forcing risky changes into the production core.",
          },
        ],
        tags: [
          "Automation Rules",
          "Dry Run",
          "Notifications",
          "Audit Log",
          "Safe Rollout",
        ],
        cover: showcaseImageMap.automationRules,
        link: "https://github.com/bdsrca/cmms-automation",
        diagram: [
          "Operational Event",
          "Rule Evaluation",
          "Dry Run",
          "Alert / Report / Action",
          "Audit Log",
        ],
      },
      {
        category: "Featured R&D System",
        title: "Megamation BASIC+ Upgrade Workstation",
        description:
          "A controlled review workflow for legacy BASIC+ upgrade work, designed to reduce blind merges and improve upgrade confidence.",
        buildLabel: "Structured the upgrade review",
        built:
          "Guides old code, new code, validation notes, and export packaging through one review workstation.",
        valueLabel: "Reduces blind upgrade risk",
        rdValue:
          "Reviewers can understand what changed, catch issues earlier, and ship upgrade packages with more confidence.",
        fields: [
          {
            label: "Problem",
            text: "Legacy BASIC+ upgrade work can be hard to review when changes are scattered, warnings are implicit, and final packaging depends on manual discipline.",
          },
          {
            label: "Technical Approach",
            text: "A local workstation compares old code, new code, and final drafts side by side, tracks validation notes, and exports only reviewed packages.",
          },
          {
            label: "Why It Matters",
            text: "Developers get a safer review workflow, and R&D gets a repeatable pattern for upgrade confidence and audit-ready handoff.",
          },
          {
            label: "Legacy System Meaning",
            text: "It helps BASIC+ continue evolving by making upgrade work more controlled, visible, and maintainable.",
          },
        ],
        tags: [
          "Legacy Modernization",
          "BASIC+",
          "Review Workflow",
          "Upgrade Safety",
          "Developer Tooling",
        ],
        cover: showcaseImageMap.megamationUpgrade,
        link: "https://github.com/bdsrca/megamationupgrade",
        diagram: [
          "Legacy Code",
          "Diff Review",
          "Validation",
          "Export Package",
          "Controlled Upgrade",
        ],
      },
    ],
  },
  {
    title: "Supporting Engineering Cases",
    accent: "emerald",
    description:
      "Supporting case studies that show broader engineering judgment across knowledge systems, reporting, data access, mobile workflows, and CMMS product usability.",
    projects: [
      {
        category: "Supporting Engineering Case",
        title: "CMMS Knowledge Base",
        description:
          "A CMMS knowledge base that turns approved docs, support patterns, and old implementation know-how into cited answers.",
        buildLabel: "Grounded answers in approved sources",
        built:
          "Retrieves from approved material, shows citations, handles low confidence, and routes weak answers back into review.",
        valueLabel: "Cuts repeated support lookup",
        rdValue:
          "Support and implementation teams get faster answers without losing the source trail.",
        fields: [
          {
            label: "Problem",
            text: "Important CMMS knowledge often lives in tickets, older docs, and senior memory, making support answers slow and inconsistent.",
          },
          {
            label: "Technical Approach",
            text: "Approved sources are indexed for retrieval, answers include citations, weak confidence routes to review, and missing knowledge becomes a content signal.",
          },
          {
            label: "Why It Matters",
            text: "Support and implementation teams can answer repeated questions faster while keeping source evidence visible.",
          },
          {
            label: "Legacy System Meaning",
            text: "It preserves DirectLine and BASIC+ knowledge as reusable product memory instead of letting it remain tribal or fragile.",
          },
        ],
        tags: [
          "Knowledge Systems",
          "Cited AI",
          "Source Governance",
          "Support Reduction",
          "Review Loop",
        ],
        cover: showcaseImageMap.knowledgeBase,
        link: "https://github.com/bdsrca/cmms-sage",
        diagram: [
          "Approved Sources",
          "Indexing",
          "Retrieval",
          "Cited Answer",
          "Review Loop",
        ],
      },
      {
        category: "Supporting Engineering Case",
        title: "CMMS Analytics, Reports, and Export API",
        description:
          "A reporting and export API concept for making CMMS operational data easier to discover, run, govern, and trust.",
        buildLabel: "Made reporting reusable",
        built:
          "Organizes report discovery, export limits, dashboard-ready outputs, and governed data access behind repeatable patterns.",
        valueLabel: "Reduces one-off report work",
        rdValue:
          "Teams can find and run trusted reports instead of starting every data question as a custom request.",
        fields: [
          {
            label: "Problem",
            text: "Reporting requests become one-off work when definitions, exports, KPIs, and dashboard-ready data are not easy to discover or govern.",
          },
          {
            label: "Technical Approach",
            text: "A report registry, export API, KPI outputs, dashboard widgets, limits, and governance rules shape reporting into repeatable data access.",
          },
          {
            label: "Why It Matters",
            text: "Reporting becomes the trust layer for operations and AI, giving teams reliable data before automation or suggestions are layered on top.",
          },
          {
            label: "Legacy System Meaning",
            text: "It helps DirectLine data remain valuable by exposing clear, governed reporting patterns without weakening the production system.",
          },
        ],
        tags: [
          "Analytics",
          "Reports",
          "Export API",
          "Data Governance",
          "Enterprise UX",
        ],
        cover: showcaseImageMap.analyticsExport,
        link: "https://github.com/bdsrca/cmms-analytics",
        diagram: ["CMMS Data", "Report Registry", "Export API", "Dashboard / KPI"],
      },
      {
        category: "Supporting Engineering Case",
        title: "CMMS Mobile PWA Architecture",
        description:
          "A mobile-first CMMS architecture for technician workflows, offline drafts, sync recovery, and field-ready work order updates.",
        buildLabel: "Designed for field conditions",
        built:
          "Supports technician input, offline drafts, sync queues, work-order updates, and audit trails for interrupted field work.",
        valueLabel: "Keeps work moving offline",
        rdValue:
          "Technicians can keep recording work even when connectivity and job flow are messy.",
        fields: [
          {
            label: "Problem",
            text: "Technicians need to capture work beside equipment, where connectivity, interruptions, and desktop-first workflows often get in the way.",
          },
          {
            label: "Technical Approach",
            text: "A mobile PWA model supports offline drafts, sync queues, work-order updates, token controls, conflict handling, and audit trails.",
          },
          {
            label: "Why It Matters",
            text: "Field teams can keep work moving while implementation and support teams get clearer mobile workflow behavior to validate.",
          },
          {
            label: "Legacy System Meaning",
            text: "It explores modern mobile experiences as an external layer that can connect back to established CMMS data and workflow rules.",
          },
        ],
        tags: [
          "Mobile CMMS",
          "Offline Drafts",
          "Technician UX",
          "Sync Safety",
          "Field Operations",
        ],
        cover: showcaseImageMap.mobilePwa,
        link: "https://github.com/bdsrca/cmms-pwa-app",
        diagram: [
          "Technician Input",
          "Offline Draft",
          "Sync Queue",
          "Work Order Update",
          "Audit Trail",
        ],
      },
    ],
  },
  {
    title: "Future Vision & Full-Stack Experiments",
    accent: "violet",
    description:
      "Forward-looking architecture ideas and independent full-stack product work that show long-term product thinking beyond daily implementation tasks.",
    projects: [
      {
        category: "Future Vision",
        title: "From CMMS to Agentic EAM",
        description:
          "A future CMMS/EAM concept where specialist agents prepare maintenance recommendations, but people and policy still decide.",
        buildLabel: "Modeled controlled delegation",
        built:
          "Uses intake, asset, inventory, and policy agents to create a review package instead of writing directly to production.",
        valueLabel: "Speeds up reasoning without silent writes",
        rdValue:
          "Maintenance teams get evidence, risk, and recommendations while approval stays visible and accountable.",
        fields: [
          {
            label: "Problem",
            text: "AI agents can create risk if they act directly on assets, inventory, or policy-sensitive workflows without structured review.",
          },
          {
            label: "Technical Approach",
            text: "Specialist agents gather intake, asset, inventory, and policy context, then package evidence and recommendations for human approval.",
          },
          {
            label: "Why It Matters",
            text: "R&D can explore agentic decision support while keeping accountability, approval, and failure paths visible.",
          },
          {
            label: "Legacy System Meaning",
            text: "It treats the existing CMMS as the system of record and positions AI as an assistant around it, not a replacement for it.",
          },
        ],
        tags: [
          "Agentic AI",
          "EAM",
          "Human Approval",
          "Decision Support",
          "Future Architecture",
        ],
        cover: showcaseImageMap.agenticEam,
        link: "https://github.com/bdsrca/MAAI-CMMS",
        diagram: [
          "Request",
          "Specialist Agent",
          "Context / Policy Check",
          "Human Approval",
          "Recommended Action",
        ],
      },
      {
        category: "Future Vision",
        title: "CMMS AI Operations Console Roadmap",
        description:
          "A CMMS engineering assistant and operations-console concept for helping users reason through configuration, troubleshooting, workflow design, and technical support scenarios.",
        buildLabel: "Mapped support into guided flows",
        built:
          "Turns configuration checks, troubleshooting, workflow design, and support questions into guided console paths.",
        valueLabel: "Keeps assistance bounded",
        rdValue:
          "Users get practical next steps without handing the whole system to an open-ended chatbot.",
        fields: [
          {
            label: "Problem",
            text: "Configuration, troubleshooting, and support questions need guided reasoning, not an open-ended chatbot that hides uncertainty.",
          },
          {
            label: "Technical Approach",
            text: "Console paths organize context checks, workflow design prompts, troubleshooting branches, suggested actions, and human review.",
          },
          {
