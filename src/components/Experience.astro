---
import { siteConfig } from "../config";
const config = Astro.props.config ?? siteConfig;
const sectionLabels = Astro.props.sectionLabels ?? {};
const hasExperience = config.experience && config.experience.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="bg-white px-6 py-12 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4 lg:sticky lg:top-24">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              {sectionLabels.experience ?? "From Client Systems to R&D"}
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${config.accentColor}`}
            />
            <p class="mt-6 max-w-sm text-base leading-7 text-gray-600">
              {sectionLabels.experienceIntro ??
                "My path combines programming, client service, implementation support, and product thinking. That mix gives me a practical view of what clients need, how the system behaves, where custom work repeats, and which ideas can become scalable product improvements."}
            </p>
          </div>

          <div class="lg:col-span-8">
            <div class="relative space-y-6 before:absolute before:left-5 before:top-4 before:h-[calc(100%-2rem)] before:w-px before:bg-gradient-to-b before:from-blue-500 before:via-slate-300 before:to-transparent">
              {config.experience.map((exp, index) => (
                <article class="relative pl-14">
                  <div
                    class="absolute left-0 top-1 grid h-10 w-10 place-items-center rounded-full border-4 border-white text-sm font-bold text-white shadow-lg"
                    style={`border-color: ${config.accentColor}; background-color: ${config.accentColor}`}
                  >
                    {String(index + 1).padStart(2, "0")}
                  </div>

                  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-200 hover:shadow-md">
                    <div class="border-b border-slate-100 bg-slate-50 px-5 py-4 sm:px-6">
                      <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                        <div>
                          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">
                            {exp.kicker ??
                              (index === 0
                                ? "Client-Facing Solution Ownership"
                                : index === 1
                                  ? "Production System Building"
                                  : "Technical Foundation")}
                          </p>
                          <h3 class="mt-2 text-xl font-bold text-gray-950 sm:text-2xl">
                            {exp.title ?? exp.role}
                          </h3>
                        </div>
                        <span class="text-sm font-medium text-gray-500">
                          {exp.dateRange}
                        </span>
                      </div>
                      <p
                        class="mt-2 text-base font-semibold"
                        style={`color: ${config.accentColor}`}
                      >
                        {exp.companyLink ? (
                          <a
                            href={exp.companyLink}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="underline decoration-current/30 underline-offset-4 transition hover:decoration-current"
                          >
                            {exp.company}
                          </a>
                        ) : (
                          exp.company
                        )}
                      </p>
                    </div>
                    <div class="p-5 sm:p-6">
                      <div class="mb-5 grid grid-cols-1 gap-2 sm:grid-cols-3">
                        {(exp.phaseLabels ??
                          (index === 0
                          ? ["Discovery", "Architecture", "Delivery"]
                          : index === 1
                            ? ["Custom Logic", "Reports", "Integration"]
                            : ["Data", "SQL", "Foundations"])
                        ).map((label) => (
                          <span class="rounded-md bg-blue-50 px-3 py-2 text-center text-xs font-semibold text-blue-800">
                            {label}
                          </span>
                        ))}
                      </div>
                      <ul class="space-y-3">
                        {exp.bullets.map((bullet) => (
                          <li class="flex items-start gap-3">
                            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gray-950" />
                            <span class="text-sm leading-6 text-gray-600 sm:text-base">
                              {bullet}
                            </span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
