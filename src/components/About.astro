---
import { siteConfig } from "../config";

const config = Astro.props.config ?? siteConfig;
const sectionLabels = Astro.props.sectionLabels ?? {};
---

<section id="about" class="bg-slate-50 px-6 py-10 sm:p-10 md:p-14 lg:p-20">
  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-1 items-start gap-8 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-3">
        <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl md:text-5xl xl:text-6xl">
          {sectionLabels.about ?? "About Me"}
        </h2>
        <div
          class="w-[75px] h-[5px] mt-2 rounded-full"
          style={`background-color: ${config.accentColor}`}
        >
        </div>
        <p class="mt-5 max-w-xs text-sm leading-7 text-gray-600">
          Capability model for internal R&D: product-aware CMMS engineering,
          legacy translation, analytics, and safe automation.
        </p>
      </div>

      <div class="space-y-7 lg:col-span-9">
        <p class="border-l-4 border-blue-600 bg-white p-5 text-base leading-7 text-gray-700 shadow-sm">
          {config.aboutMe}
        </p>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
          {config.capabilityModel?.map((capability) => (
            <article class="group rounded-lg border border-slate-200 bg-white p-4 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-200 hover:shadow-md">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-gray-950 text-white">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-5 w-5"
                  aria-hidden="true"
                >
                  <path d="M4 6h16M4 12h10M4 18h16" />
                </svg>
              </div>
              <h3 class="text-lg font-bold leading-tight text-gray-950">
                {capability.title}
              </h3>
              <p class="mt-3 text-sm leading-6 text-gray-600">
                {capability.summary}
              </p>
              <div class="mt-4 flex flex-wrap gap-2">
                {capability.signals.slice(0, 5).map((signal) => (
                  <span class="rounded-md bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">
                    {signal}
                  </span>
                ))}
              </div>
            </article>
          ))}
        </div>

        <div class="hidden md:block">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">
            Working vocabulary
          </p>
          <div class="flex flex-wrap gap-2">
            {
              config.skills.slice(0, 28).map((skill) => (
                <span class="rounded-md bg-white px-3 py-1.5 text-sm font-medium text-gray-700 shadow-sm ring-1 ring-slate-200 transition-colors duration-200 hover:bg-blue-50 hover:text-blue-800">
                  {skill}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
