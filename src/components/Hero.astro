---
import { siteConfig } from "../config";

const config = Astro.props.config ?? siteConfig;
const heroLabels = Astro.props.heroLabels ?? {};
const identityImage = config.avatarImage ?? config.profileImage;
---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-white py-24 md:min-h-screen"
  style={`--accent-color: ${config.accentColor}`}
>
  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 -z-10"
    style={`background: radial-gradient(ellipse 800px 1200px at 0% 0%, ${config.accentColor}40 0%, ${config.accentColor}25 20%, ${config.accentColor}10 40%, rgba(255, 255, 255, 0.3) 70%, rgba(255, 255, 255, 0.8) 90%, white 100%)`}
  >
  </div>
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
  >
    <defs>
      <pattern
        x="50%"
        y={-1}
        id="0787a7c5-978c-4f66-83c7-11c213f99cb7"
        width={200}
        height={200}
        patternUnits="userSpaceOnUse"
      >
        <path d="M.5 200V.5H200" fill="none"></path>
      </pattern>
      <pattern
        id="programming-symbols"
        x="0"
        y="0"
        width="400"
        height="400"
        patternUnits="userSpaceOnUse"
      >
        <text
          x="50"
          y="50"
          fill={config.accentColor}
          font-family="monospace"
          font-size="24"
          transform="rotate(-15)">&lt;/&gt;</text
        >
        <text
          x="150"
          y="100"
          fill={config.accentColor}
          font-family="monospace"
          font-size="20"
          transform="rotate(10)">{}</text
        >
        <text
          x="250"
          y="80"
          fill={config.accentColor}
          font-family="monospace"
          font-size="18"
          transform="rotate(-5)">=&gt;</text
        >
        <text
          x="100"
          y="200"
          fill={config.accentColor}
          font-family="monospace"
          font-size="22"
          transform="rotate(15)">[]</text
        >
        <text
          x="300"
          y="180"
          fill={config.accentColor}
          font-family="monospace"
          font-size="20"
          transform="rotate(-10)">&lt;&gt;</text
        >
        <text
          x="200"
          y="250"
          fill={config.accentColor}
          font-family="monospace"
          font-size="24"
          transform="rotate(5)">()</text
        >
        <text
          x="50"
          y="320"
          fill={config.accentColor}
          font-family="monospace"
          font-size="18"
          transform="rotate(-8)">::</text
        >
        <text
          x="350"
          y="300"
          fill={config.accentColor}
          font-family="monospace"
          font-size="22"
          transform="rotate(12)">==</text
        >
        <text
          x="150"
          y="350"
          fill={config.accentColor}
          font-family="monospace"
          font-size="20"
          transform="rotate(-15)">++</text
        >
        <text
          x="250"
          y="370"
          fill={config.accentColor}
          font-family="monospace"
          font-size="24"
          transform="rotate(8)">;</text
        >
      </pattern>
    </defs>
    <rect
      fill="url(#programming-symbols)"
      width="100%"
      height="100%"
      opacity="0.2"></rect>
    <rect
      fill="url(#0787a7c5-978c-4f66-83c7-11c213f99cb7)"
      width="100%"
      height="100%"
      stroke-width={0}></rect>
  </svg>
  <div class="absolute inset-0 -z-10 opacity-50">
    <svg class="h-full w-full" viewBox="0 0 1400 900" fill="none" aria-hidden="true">
      <path d="M100 190H360C430 190 430 270 500 270H760C840 270 840 190 920 190H1260" stroke="#2563eb" stroke-width="1.5" stroke-dasharray="8 12" />
      <path d="M180 640H420C500 640 500 560 580 560H860C930 560 930 640 1000 640H1260" stroke="#0f172a" stroke-width="1" stroke-dasharray="4 10" opacity="0.35" />
      <circle cx="360" cy="190" r="7" fill="#2563eb" />
      <circle cx="760" cy="270" r="7" fill="#2563eb" />
      <circle cx="920" cy="190" r="7" fill="#2563eb" />
      <circle cx="580" cy="560" r="6" fill="#10b981" />
      <circle cx="1000" cy="640" r="6" fill="#f59e0b" />
      <rect x="1050" y="300" width="210" height="84" rx="14" fill="#ffffff" stroke="#bfdbfe" opacity="0.75" />
      <path d="M1080 330H1230M1080 354H1180" stroke="#2563eb" stroke-width="6" stroke-linecap="round" opacity="0.35" />
      <rect x="125" y="405" width="230" height="110" rx="16" fill="#ffffff" stroke="#cbd5e1" opacity="0.7" />
      <path d="M155 438H295M155 466H250M155 494H315" stroke="#0f172a" stroke-width="5" stroke-linecap="round" opacity="0.18" />
    </svg>
  </div>
  <div
    class="mx-auto flex min-h-[calc(100vh-8rem)] flex-col items-start justify-center gap-8 p-6 pt-24 sm:p-12 md:p-24 lg:flex-row lg:items-center lg:justify-between lg:gap-16"
  >
    <div class="max-w-5xl">
      <h2
        class="text-pretty text-xl sm:text-2xl md:text-4xl font-bold tracking-tight text-gray-700 animate-fade-in"
      >
        {heroLabels.greeting ?? "Hello."}
      </h2>
      <h1
        class="mt-6 sm:mt-8 text-pretty text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-bold tracking-tight text-gray-800 animate-fade-in animation-delay-200"
      >
        {heroLabels.namePrefix ?? "I'm"} <span style={{ color: config.accentColor }}
          >{config.name}</span
        >
      </h1>
      {
        config.positioning && (
          <p class="mt-6 max-w-5xl text-pretty text-2xl font-semibold leading-tight text-gray-900 sm:text-3xl md:text-4xl animate-fade-in animation-delay-400">
            {config.positioning}
          </p>
        )
      }
      <p
        class="mt-5 text-pretty text-sm font-semibold uppercase tracking-[0.22em] text-gray-500 animate-fade-in animation-delay-600"
      >
        {config.title}
      </p>
      {
        config.heroDescription && (
          <p class="mt-6 hidden max-w-4xl text-pretty text-base text-gray-600 animate-fade-in animation-delay-600 sm:block md:text-lg/8">
            {config.heroDescription}
          </p>
        )
      }
      <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap animate-fade-in animation-delay-600">
        <a
          href="#showcases"
          class="inline-flex items-center justify-center gap-2 rounded-md bg-gray-950 px-4 py-3 text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-gray-800"
        >
          {heroLabels.primaryCta ?? "Start with the 9-project R&D map"}
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="#experience"
          class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-3 text-sm font-semibold text-gray-950 transition-all duration-300 hover:-translate-y-0.5 hover:border-blue-300 hover:bg-blue-50"
        >
          {heroLabels.secondaryCta ?? "View Technical Evidence"}
        </a>
      </div>
    </div>
    {
      config.profileImage && (
        <div class="w-full max-w-xs shrink-0 animate-fade-in animation-delay-400 sm:max-w-sm lg:max-w-md">
          <div class="overflow-hidden rounded-full border border-gray-200 bg-gray-950 shadow-2xl shadow-blue-950/20">
            <img
              src={identityImage}
              alt={`${config.name} avatar`}
              class="aspect-square w-full object-cover"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      )
    }
  </div>
  {identityImage && (
    <div class="pointer-events-none absolute bottom-8 left-0 hidden w-full overflow-hidden md:block">
      <img
        src={identityImage}
        alt=""
        class="cat-walk h-10 w-10 rounded-full object-cover opacity-80 ring-1 ring-blue-200/70"
        loading="lazy"
      />
    </div>
  )}
  <div
    class="absolute bottom-0 left-0 right-0 hidden p-8 text-gray-700 animate-fade-in animation-delay-600 sm:flex sm:gap-x-6 sm:p-12 md:gap-x-8 md:p-24"
  >
    {
      config.social?.email && (
        <a
          href={`mailto:${config.social.email}`}
          aria-label="Email"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
            <path d="M3 7l9 6l9 -6" />
          </svg>
        </a>
      )
    }
    {
      config.social?.linkedin && (
        <a
          href={config.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <>
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M8 11v5" />
              <path d="M8 8v.01" />
              <path d="M12 16v-5" />
              <path d="M16 16v-3a2 2 0 1 0 -4 0" />
              <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
            </>
          </svg>
        </a>
      )
    }
    {
      config.social?.twitter && (
        <a
          href={config.social.twitter}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Twitter"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <>
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M4 4l11.733 16h4.267l-11.733 -16z" />
              <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772" />
            </>
          </svg>
        </a>
      )
    }
    {
      config.social?.github && (
        <a
          href={config.social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
          >
            <>
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
            </>
          </svg>
        </a>
      )
    }
  </div>
</div>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }

  .animation-delay-400 {
    animation-delay: 0.4s;
  }

  .animation-delay-600 {
    animation-delay: 0.6s;
  }

  .cat-walk {
    animation: catWalk 18s linear infinite;
  }

  @keyframes catWalk {
    from {
      transform: translateX(-64px);
    }
    to {
      transform: translateX(calc(100vw + 64px));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cat-walk {
      animation: none;
      transform: translateX(24px);
    }
  }
</style>
