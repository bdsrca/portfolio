---
import { siteConfig } from "../config";

const config = Astro.props.config ?? siteConfig;
const navLabels = Astro.props.navLabels ?? {};

const hasProjects = config.projects && config.projects.length > 0;
const hasWorkingStyle =
  config.workingStyle && config.workingStyle.qualities.length > 0;
const hasExperience = config.experience && config.experience.length > 0;
const hasEducation = config.education && config.education.length > 0;
const hasWhyRnd = !!config.whyRnd;

const mobileLinks = [
  hasWhyRnd && { href: "#why-rnd", label: navLabels.mobileWhy ?? "R&D", icon: "M12 3v18 M3 12h18" },
  { href: "#about", label: navLabels.mobileAbout ?? "About", icon: "M12 12a4 4 0 1 0 0 -8a4 4 0 0 0 0 8z M4 21a8 8 0 0 1 16 0" },
  hasProjects && { href: "#showcases", label: navLabels.mobileCases ?? "Cases", icon: "M4 5h16v14h-16z M8 9h8 M8 13h5" },
  hasWorkingStyle && { href: "#working-style", label: navLabels.mobileStyle ?? "Style", icon: "M5 12h14 M12 5v14 M7 7l10 10" },
  hasExperience && { href: "#experience", label: navLabels.mobilePath ?? "Path", icon: "M4 6h16 M4 12h10 M4 18h16" },
].filter(Boolean);
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 hidden md:block transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-8 py-4">
    <ul class="flex items-center gap-8 justify-center">
      {
        hasWhyRnd && (
          <li>
            <a
              href="#why-rnd"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              {navLabels.why ?? "Why R&D"}
            </a>
          </li>
        )
      }
      <li>
        <a
          href="#about"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {navLabels.about ?? "About"}
        </a>
      </li>
      {
        hasWorkingStyle && (
          <li>
            <a
              href="#working-style"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              {navLabels.style ?? "Style"}
            </a>
          </li>
        )
      }
      {
        hasProjects && (
          <li>
            <a
              href="#showcases"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              {navLabels.showcases ?? "Showcases"}
            </a>
          </li>
        )
      }
      {
        hasExperience && (
          <li>
            <a
              href="#experience"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              {navLabels.experience ?? "Experience"}
            </a>
          </li>
        )
      }
      {
        hasEducation && (
          <li>
            <a
              href="#education"
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              {navLabels.education ?? "Education"}
            </a>
          </li>
        )
      }
    </ul>
  </nav>
</header>

<nav
  class="fixed bottom-3 left-3 right-3 z-50 rounded-lg border border-slate-200 bg-white/90 px-2 py-2 shadow-xl shadow-slate-900/10 backdrop-blur md:hidden"
  aria-label="Mobile navigation"
>
  <ul class="grid grid-cols-5 gap-1">
    {mobileLinks.map((link) => (
      <li>
        <a
          href={link.href}
          class="flex flex-col items-center justify-center rounded-md px-2 py-2 text-[11px] font-semibold text-slate-600 transition-colors hover:bg-blue-50 hover:text-blue-700"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mb-1 h-4 w-4"
            aria-hidden="true"
          >
            <path d={link.icon} />
          </svg>
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (window.scrollY > 100) {
      header?.classList.add("bg-white/80", "backdrop-blur-sm");
    } else {
      header?.classList.remove("bg-white/80", "backdrop-blur-sm");
    }
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
