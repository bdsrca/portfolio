---
import { siteConfig } from "../config";

const whyRnd = siteConfig.whyRnd;
---

{
  whyRnd && (
    <section id="why-rnd" class="bg-white px-6 py-12 sm:p-12 md:p-16 lg:p-24">
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-4">
          <h2 class="text-3xl font-bold text-gray-950 sm:text-4xl md:text-5xl">
            Why R&D
          </h2>
          <div
            class="mt-2 h-[5px] w-[75px] rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />
        </div>

        <div class="lg:col-span-8">
          <div class="rounded-lg border border-slate-200 bg-slate-50 p-5 shadow-sm sm:p-6 md:p-8">
            <p class="text-base leading-7 text-gray-700 sm:text-lg">
              {whyRnd.intro}
            </p>
            <p class="mt-4 text-base leading-7 text-gray-700 sm:text-lg">
              {whyRnd.detail}
            </p>
            <div class="mt-6 grid grid-cols-1 gap-3 md:grid-cols-3">
              {whyRnd.points.map((point) => (
                <div class="rounded-md bg-white p-4 text-sm font-medium leading-6 text-gray-700 ring-1 ring-slate-200">
                  {point}
                </div>
              ))}
            </div>

            {whyRnd.lightSystem && (
              <div class="mt-8 rounded-lg border border-blue-100 bg-white p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-blue-700">
                  {whyRnd.lightSystem.title}
                </p>
                <p class="mt-3 text-sm leading-7 text-gray-700 sm:text-base">
                  {whyRnd.lightSystem.intro}
                </p>
                <div class="mt-5 grid grid-cols-1 gap-3 md:grid-cols-3">
                  {whyRnd.lightSystem.sections.map((section) => (
                    <article class="rounded-md bg-slate-50 p-4 ring-1 ring-slate-200">
                      <h3 class="text-sm font-bold text-gray-950">
                        {section.title}
                      </h3>
                      <p class="mt-2 text-sm leading-6 text-gray-600">
                        {section.body}
                      </p>
                    </article>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  )
}
