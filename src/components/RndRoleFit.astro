---
import { siteConfig } from "../config";

const config = Astro.props.config ?? siteConfig;
const sectionLabels = Astro.props.sectionLabels ?? {};
const roleFit = config.rndRoleFit;
---

{
  roleFit && (
    <section id="rnd-role-fit" class="bg-slate-50 px-6 py-12 sm:p-12 md:p-16 lg:p-24">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-4">
            <h2 class="text-3xl font-bold text-gray-950 sm:text-4xl md:text-5xl">
              {sectionLabels.roleFit ?? "Where I Can Help R&D"}
            </h2>
            <div
              class="mt-2 h-[5px] w-[75px] rounded-full"
              style={`background-color: ${config.accentColor}`}
            />
          </div>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:col-span-8">
            {roleFit.map((item) => (
              <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                <h3 class="text-lg font-bold leading-tight text-gray-950">
                  {item.title}
                </h3>
                <p class="mt-3 text-sm leading-6 text-gray-600">
                  {item.summary}
                </p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}
